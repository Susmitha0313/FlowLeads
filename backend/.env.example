PORT=3000
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
NODE_ENV=development

# LinkedIn OAuth — get from LinkedIn Developer Console
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_REDIRECT_URI=https://your-deployed-backend.com/api/auth/linkedin/callback
APP_DEEP_LINK_SCHEME=bobi

# JWT — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret
